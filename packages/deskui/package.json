{
  "name": "deskui",
  "version": "0.1.0",
  "description": "A desktop OS shell for your web app — windows, dock, taskbar, and themes.",
  "license": "MIT",
  "keywords": [
    "desktop",
    "os",
    "window-manager",
    "dock",
    "taskbar",
    "react",
    "next.js",
    "ui",
    "shell"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gitaumoses4/deskui.git",
    "directory": "packages/deskui"
  },
  "homepage": "https://github.com/gitaumoses4/deskui",
  "bugs": "https://github.com/gitaumoses4/deskui/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./src/*": "./src/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "zustand": "^4.5.0",
    "uuid": "^9.0.0"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "next": "^14.0.0"
  }
}
